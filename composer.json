{
  "name": "roots/bedrock",
  "type": "project",
  "license": "MIT",
  "description": "Delidej WordPress (Bedrock)",
  "homepage": "https://roots.io/bedrock/",
  "keywords": [
    "bedrock", "composer", "roots", "wordpress", "wp", "wp-config"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    }
  ],
  "require": {
    "php": ">=7.1",
    "composer/installers": "^2.2",
    "oscarotero/env": "^2.1.0",
    "roots/wordpress": "^7.0",
    "roots/wp-config": "1.0.0",
    "roots/wp-password-bcrypt": "1.2.0",
    "vlucas/phpdotenv": "^5.6.0",
    "wp-cli/wp-cli-bundle": "2.11.*",
    "wpackagist-plugin/better-search-replace": "1.4.10",
    "wpackagist-plugin/child-theme-configurator": "2.6.7",
    "wpackagist-plugin/complianz-gdpr": "7.5.0",
    "wpackagist-plugin/disable-xml-rpc-api": "2.1.7",
    "wpackagist-plugin/elementor": "4.1.3",
    "wpackagist-plugin/fluent-crm": "3.1.5",
    "wpackagist-plugin/fluent-support": "2.2.1",
    "wpackagist-plugin/google-site-kit": "1.181.0",
    "wpackagist-plugin/mollie-payments-for-woocommerce": "8.1.7",
    "wpackagist-plugin/simple-cloudflare-turnstile": "1.40.0",
    "wpackagist-plugin/simple-page-ordering": "2.8.0",
    "wpackagist-plugin/translatepress-multilingual": "3.2.2",
    "wpackagist-plugin/ultimate-faqs": "2.4.11",
    "wpackagist-plugin/ultimate-member": "2.12.0",
    "wpackagist-plugin/woocommerce": "10.8.1",
    "wpackagist-plugin/woocommerce-pdf-invoices-packing-slips": "5.14.0",
    "wpackagist-plugin/wp-mail-smtp": "4.8.0",
    "wpackagist-theme/hello-elementor": "^3.4",
    "wpackagist-plugin/insert-headers-and-footers": "2.3.6",
    "wpackagist-plugin/when-last-login": "1.2.3",
    "wpackagist-plugin/woo-thank-you-page-customizer": "1.2.0" 
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.4.2",
    "roave/security-advisories": "dev-master"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "wordpress-install-dir": "web/wp"
  },
  "scripts": {
    "post-root-package-install": [
      "php -r \"copy('.env.example', '.env');\""
    ]
  }
}
